# ── 环境变量 / 密钥（禁止上传）──────────────────────────────────
.env
.env.*
!.env.example

# ── 图片 / 测试素材 ──────────────────────────────────────────────
/food_pic
*.jpg
*.jpeg
*.png
*.webp

# ── 上传的临时图片（保留目录本身）──────────────────────────────
/backend/uploads/*
!backend/uploads/.gitkeep

# ── 无关目录 ─────────────────────────────────────────────────────
/minicode-1

# ── Python 缓存 ──────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyz

# ── 打包 / 安装产物 ──────────────────────────────────────────────
*.egg-info/
*.egg
dist/
build/

# ── 数据库文件 ──────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── 向量数据库 / 知识库缓存 ─────────────────────────────────────
*.faiss
*.pkl
*_chroma/
nutrition_knowledge/

# ── 日志 ────────────────────────────────────────────────────────
*.log
logs/

# ── IDE / 系统文件 ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
